{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.stylelint": "explicit"
  },
  "stylelint.validate": ["css", "scss", "vue", "html"],
  "stylelint.packageManager": "pnpm",
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false
}
